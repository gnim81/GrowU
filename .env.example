# Set for Docker Compose and any direct Postgres usage.
POSTGRES_PASSWORD=""

# Set for non-Docker/local Prisma or Next usage; Docker Compose builds the app DB URL itself.
DATABASE_URL=""

# Set to a long random secret for auth/session signing.
AUTH_SECRET=""
AUTH_COOKIE_SECURE="false"

# Optional: only used when upgrading from legacy environment-configured accounts.
GROWU_ACCOUNTS=""
