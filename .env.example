# Required for Docker Compose Postgres and any direct Postgres usage.
POSTGRES_PASSWORD=""

# Required for Docker Compose app runtime and non-Docker/local Prisma or Next usage.
# URL-encode credentials in this value if they contain reserved URI characters.
DATABASE_URL=""

# Set to a long random secret for auth/session signing.
AUTH_SECRET=""
AUTH_COOKIE_SECURE="false"

# Optional: only used when upgrading from legacy environment-configured accounts.
GROWU_ACCOUNTS=""
